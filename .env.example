# Copy this file to .env and fill in real values for this center's deployment.

# --- Database (Postgres on your VPS) ---
DATABASE_URL="postgresql://diagnostic_app:changeme@localhost:5432/diagnostic_center?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Bootstrap admin account created by `npm run db:seed` if no staff users exist yet.
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_PHONE="+8801700000000"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-this-password"
# Optional shared password for demo staff rows (Admin/Staff/Technician × Active/Inactive).
# Defaults to SEED_ADMIN_PASSWORD when unset.
# SEED_STAFF_PASSWORD="change-this-password"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Report storage ---
# Absolute path on the VPS where uploaded report PDFs are stored.
REPORTS_STORAGE_DIR="./storage/reports"

# --- SMS gateway (see src/lib/sms.ts) ---
# Set SMS_PROVIDER=console during development to log messages instead of sending them.
SMS_PROVIDER="console"
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER_ID=""

# --- Email / SMTP (see src/lib/email.ts) ---
# Leave unset in development — messages are logged to the console.
# Required to deliver contact-inquiry replies and booking emails in production.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""


# --- Demo / development helpers ---
# While siteConfig.payment.provider is "demo", forms are prefilled and OTP
# bypass stays on even in production (so visitors can explore the site).
# Switch payment to "live" before go-live to turn these off in production.
#
# Set to false to leave forms empty (and hide demo prefills).
# DEV_TOOLS=false
# NEXT_PUBLIC_DEV_TOOLS=false
#
# OTP PLACEHOLDER: any non-empty OTP is accepted in demo/dev so you can walk
# the patient portal without SMS. Real verification is in src/lib/phone-otp.ts.
# DEV_OTP_BYPASS=false
