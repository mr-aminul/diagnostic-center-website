# Copy this file to .env and fill in real values for this center's deployment.

# --- Database (Postgres on your VPS) ---
DATABASE_URL="postgresql://diagnostic_app:changeme@localhost:5432/diagnostic_center?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Bootstrap admin account created by `npm run db:seed` if no staff users exist yet.
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_PHONE="+8801700000000"
SEED_ADMIN_PASSWORD="change-this-password"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Report storage ---
# Absolute path on the VPS where uploaded report PDFs are stored.
REPORTS_STORAGE_DIR="./storage/reports"

# --- SMS gateway (see src/lib/sms.ts) ---
# Set SMS_PROVIDER=console during development to log messages instead of sending them.
SMS_PROVIDER="console"
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER_ID=""

# --- Development helpers (DISABLED automatically when NODE_ENV=production) ---
# Subtle "fill" buttons on forms. Set to false to hide locally.
# DEV_TOOLS=false
# NEXT_PUBLIC_DEV_TOOLS=false
#
# OTP PLACEHOLDER: any non-empty OTP is accepted while developing so you can
# walk Track without SMS. Real verification already exists in src/lib/phone-otp.ts.
# Before go-live: leave unset (production hard-blocks bypass) or set:
# DEV_OTP_BYPASS=false
# to test real OTP matching locally.
